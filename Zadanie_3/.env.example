# PostgreSQL (host execution; when running from host use localhost)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lankovacka
POSTGRES_USER=langflow
POSTGRES_PASSWORD=langflow

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=kb_lankovacka
LONG_TERM_MEMORY_COLLECTION=long_term_memory

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.1

# Auto-start Zadanie_2 Docker dependencies when running Zadanie_3 locally
AUTO_BOOTSTRAP_Z2_STACK=true
BOOTSTRAP_WAIT_SECONDS=120

# SQL backend mode
# SQL_BACKEND_MODE: native | mcp | auto
SQL_BACKEND_MODE=auto
SQL_MCP_SERVER_PATH=mcp_server/mcp_postgres_server.py
SQL_RUNTIME_FALLBACK=true

# Backward compatibility (optional)
USE_MCP_SQL=true
MCP_SQL_SERVER_PATH=mcp_server/mcp_postgres_server.py

# Web search
WEB_SEARCH_MAX_RESULTS=5
# WEB_BACKEND_MODE: native | mcp | auto
WEB_BACKEND_MODE=auto
TAVILY_MCP_SERVER_PATH=mcp_server/mcp_tavily_server.py
WEB_RUNTIME_FALLBACK=true
TAVILY_API_KEY=

# Logging / tracing
LOG_LEVEL=INFO
LANGSMITH_TRACING=false
# Optional if tracing=true:
# LANGSMITH_API_KEY=...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=zadanie3-plan-execute

